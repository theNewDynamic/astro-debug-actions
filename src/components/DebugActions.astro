---
import site from '@data/site';
import DebugSection from "./DebugSection.astro";
import DebugIcon from "../icons/debug.svg";
import CheckIcon from "../icons/check.svg";
import XmarkIcon from "../icons/xmark.svg";
import LinkIcon from "../icons/link.svg";
import astroPkg from 'astro/package.json';
import config from 'virtual:tnd/debug-actions';
import type { Badge } from '../types.js';

interface Props {
  entry: { url: string; id?: string };
  /**
   * Arbitrary label/value/color rows shown as stacked tabs on the closed handle, and as rows in
   * the Project section — e.g. a Sanity dataset, environment name, or tenant. Passed as a prop
   * (rather than an integration option) since these values often come from request-scoped
   * runtime env (e.g. Cloudflare bindings), unavailable when astro.config.mjs is evaluated.
   * Omit (or pass `false`) to disable. Each badge's `color` is optional and defaults to black.
   */
  badges?: Badge[] | false;
}

const { entry: {url, id}, badges = false } = Astro.props as Props;
const { breakpoints } = config;

const sortedBreakpoints = breakpoints ? [...breakpoints].sort((a, b) => a.minWidth - b.minWidth) : [];

// Breakpoint and badge colors are arbitrary per-project values, so these rules can't be written
// statically. Astro's CSP hasher only covers literal <style> content, not set:html or
// style="" attributes, so instead of emitting either we ship them as data and insert
// them via the CSSOM at runtime (see the <script> below) — style-src doesn't restrict
// CSSStyleSheet.insertRule().
const dynamicRules = sortedBreakpoints.flatMap((bp, i) => {
  const next = sortedBreakpoints[i + 1];
  const colorRules = [
    `.debug-actions .handle{background-color:${bp.color};}`,
    `.debug-actions .box{border-color:${bp.color};}`,
    `.debug-actions .viewport-label[data-bp="${bp.name}"]{background-color:${bp.color};}`,
  ];
  const visibilityConditions = [`(min-width: ${bp.minWidth}px)`];
  if (next) visibilityConditions.push(`(max-width: ${next.minWidth - 1}px)`);
  return [
    ...(bp.minWidth > 0 ? [`@media (min-width: ${bp.minWidth}px){${colorRules.join('')}}`] : colorRules),
    `@media ${visibilityConditions.join(' and ')}{.debug-actions .viewport-label[data-bp="${bp.name}"]{display:inline-block;}}`,
  ];
});
if (sortedBreakpoints.length) dynamicRules.unshift('.debug-actions .viewport-label{display:none;}');
if (badges) {
  badges.forEach((b, i) => {
    if (b.color) dynamicRules.push(`.debug-actions .badge[data-badge-index="${i}"]{background-color:${b.color};}`);
  });
}
---
<style>
  .debug-actions{
    --w: 300px;
    --border-width: 3px;
    width: var(--w);
    bottom: 6rem;
    pointer-events: none;
  }
  .debug-actions{
      left: 100%;
      transition: transform 300ms ease-in-out;

  }
  .debug-actions .handle-group{
    pointer-events: auto;
    right: calc(var(--w) - var(--border-width));
    bottom: 0;
  }
  .debug-actions .box{
    pointer-events: none;
    border-style: solid;
    border-width: var(--border-width);
    border-right-width: 0;
  }
  .debug-actions:hover .box, .debug-actions:focus-within .box, .debug-actions.is-open .box{
    pointer-events: auto;
  }
  .debug-actions:hover, .debug-actions:focus-within, .debug-actions.is-open{
    transform: translateX(-100%);
  }
  .debug-actions.force-closed{
    transform: none !important;
  }
  .debug-actions .icon-open{
    display: none;
  }
  .debug-actions.is-open .icon-closed{
    display: none;
  }
  .debug-actions.is-open .icon-open{
    display: inline;
  }
  @keyframes viewport-pop{
    from{ transform: translateY(2px); opacity: 0.3; }
    to{ transform: translateY(0); opacity: 1; }
  }
  .viewport-pop{
    animation: viewport-pop 250ms ease-out;
  }
  @media (prefers-reduced-motion: reduce){
    .viewport-pop{
      animation: none;
    }
  }
</style>

<div class="debug-actions fixed z-[1000] text-white" data-dynamic-rules={dynamicRules.length ? JSON.stringify(dynamicRules) : undefined}>
  <div class="absolute handle-group flex flex-col items-end gap-[var(--border-width)]">
    {badges && badges.map((b, i) => (
      <div class="badge bg-black rounded-l-lg pl-2 pr-1 py-1 text-center text-xs font-medium whitespace-nowrap text-white mr-[var(--border-width)]" data-badge-index={i} aria-hidden="true">{b.value}</div>
    ))}
    <button type="button" class="handle flex items-center justify-center p-2 rounded-l-lg bg-black transition-colors" aria-label="Show debug actions">
      <DebugIcon fill="currentColor" width="1rem" />
    </button>
  </div>
  <div class="items-stretch bg-black rounded-tl-lg px-3 border-black box transition-colors">
    <div class="py-1 border-b border-white">
      <div class="text-lg">Debug Info</div>
    </div>
    <div class="gap-4 flex flex-col pb-1 pt-4">
      <DebugSection title="Project">
        {breakpoints && <div>
          Breakpoint: {breakpoints.map((bp) => (
            <span
              class="viewport-pop viewport-label rounded px-2 py-0.5 text-xs font-medium text-white"
              data-bp={bp.name}
            >{bp.name} - ≥{bp.minWidth}px</span>
          ))}
        </div>}
        {badges && badges.map((b, i) => (
          <div>
            {b.label}: <span class="badge bg-black viewport-pop rounded px-2 py-0.5 text-xs font-medium text-white" data-badge-index={i}>{b.value}</span>
          </div>
        ))}
        <div>Astro: v{astroPkg.version}</div>
        <slot name="project" />
      </DebugSection>
      <DebugSection title="Page">
        <a target="_blank" class="w-fit font-bold text-emerald-400 underline underline-offset-4 hover:text-emerald-300" href={`${site.url}${!Astro.url.pathname.includes('preview') ? Astro.url.pathname : url}`}>Production URL</a>
        {id && <div>
          ID: {id}
        </div>}
        <slot name="page" />
      </DebugSection>
      <DebugSection title="Block">
        <div class="flex items-center gap-2">
          <div class="block-hover-info text-white/50">Hover a block…</div>
          <button type="button" class="copy-block-url hidden shrink-0 cursor-pointer text-white/70 hover:text-white" aria-label="Copy block URL" title="Copy block URL">
            <LinkIcon class="icon-copy" fill="currentColor" width="0.85rem" />
            <CheckIcon class="icon-copied hidden" fill="currentColor" width="0.85rem" />
          </button>
        </div>
        <slot name="block" />
      </DebugSection>

      <slot name="sections" />

      <div class="flex items-center gap-2">
        <button type="button" class="pin-toggle cursor-pointer inline-flex w-fit items-center gap-1.5 rounded-md bg-white/20 px-2 py-1 text-xs transition hover:bg-white/30">
          <CheckIcon class="icon-closed" fill="currentColor" width="0.75rem" />
          <XmarkIcon class="icon-open" fill="currentColor" width="0.75rem" />
          <span class="label">Keep open</span>
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  const debugActionsPanel = document.querySelector<HTMLElement>('.debug-actions');
  const dynamicRulesRaw = debugActionsPanel?.dataset.dynamicRules;
  if (dynamicRulesRaw) {
    const dynamicStylesheet = document.createElement('style');
    document.head.appendChild(dynamicStylesheet);
    const sheet = dynamicStylesheet.sheet;
    if (sheet) {
      (JSON.parse(dynamicRulesRaw) as string[]).forEach((rule) => sheet.insertRule(rule, sheet.cssRules.length));
    }
  }

  document.querySelectorAll('.debug-actions .pin-toggle').forEach((toggle) => {
    toggle.addEventListener('click', () => {
      const panel = toggle.closest('.debug-actions');
      if (!panel) return;
      const isOpen = panel.classList.toggle('is-open');
      const label = toggle.querySelector('.label');
      if (label) label.textContent = isOpen ? 'Hide' : 'Keep open';

      if (!isOpen) {
        panel.classList.add('force-closed');
        toggle.blur();
        const clearForceClosed = (event: Event) => {
          if (event.type === 'focusout' && panel.contains((event as FocusEvent).relatedTarget as Node)) return;
          panel.classList.remove('force-closed');
          panel.removeEventListener('mouseleave', clearForceClosed);
          panel.removeEventListener('focusout', clearForceClosed);
        };
        panel.addEventListener('mouseleave', clearForceClosed);
        panel.addEventListener('focusout', clearForceClosed);
      }
    });
  });

  document.querySelectorAll('.debug-actions .copy-block-url').forEach((button) => {
    button.addEventListener('click', async () => {
      const blockId = (button as HTMLElement).dataset.blockId;
      if (!blockId) return;
      const url = `${location.origin}${location.pathname}#${blockId}`;
      await navigator.clipboard.writeText(url);

      button.querySelector('.icon-copy')?.classList.add('hidden');
      button.querySelector('.icon-copied')?.classList.remove('hidden');
      window.setTimeout(() => {
        button.querySelector('.icon-copy')?.classList.remove('hidden');
        button.querySelector('.icon-copied')?.classList.add('hidden');
      }, 1200);
    });
  });

  document.addEventListener('mouseover', (event: MouseEvent) => {
    const panel = document.querySelector('.debug-actions');
    const info = panel?.querySelector('.block-hover-info');
    const copyButton = panel?.querySelector<HTMLElement>('.copy-block-url');
    if (!panel?.classList.contains('is-open') || !info) return;
    if ((event.target as HTMLElement).closest('.debug-actions')) return;

    const blockEl = (event.target as HTMLElement).closest<HTMLElement>('[data-block-id]');
    info.classList.toggle('text-white/50', !blockEl);
    info.classList.toggle('text-white', !!blockEl);
    if (!blockEl) {
      info.textContent = 'Hover a block…';
      copyButton?.classList.add('hidden');
      if (copyButton) delete copyButton.dataset.blockId;
      return;
    }
    const { blockId, blockComponent, blockTitle } = blockEl.dataset;
    info.textContent = `${blockComponent || '?'}${blockTitle ? ` — ${blockTitle}` : ''} (#${blockId})`;
    if (copyButton && blockId) {
      copyButton.dataset.blockId = blockId;
      copyButton.classList.remove('hidden');
    }
  });
</script>
